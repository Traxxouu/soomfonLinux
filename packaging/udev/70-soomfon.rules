# udev rules for Soomfon (Mirabox / Ajazz OEM) stream deck devices.
#
# These devices ship under several OEM vendor ids. Granting "uaccess" lets the
# logged-in user open the HID interfaces without running as root.
#
# The 70- prefix matters: systemd's 73-seat-late.rules runs the "uaccess"
# builtin, so the tag must be set by an earlier-numbered file (< 73) or the ACL
# is never applied.
#
# Install:
#   sudo cp packaging/udev/70-soomfon.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# Then unplug and replug the device.
#
# Vendor ids, by family:
#   1500  Soomfon          (e.g. Stream Controller SE, idProduct 3001)
#   0300  Ajazz            (AKP03 family)
#   6602  N3
#   6603  Mirabox          (N3EN)

SUBSYSTEM=="usb", ATTRS{idVendor}=="1500", TAG+="uaccess", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="1500", TAG+="uaccess", MODE="0660"

SUBSYSTEM=="usb", ATTRS{idVendor}=="0300", TAG+="uaccess", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0300", TAG+="uaccess", MODE="0660"

SUBSYSTEM=="usb", ATTRS{idVendor}=="6602", TAG+="uaccess", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="6602", TAG+="uaccess", MODE="0660"

SUBSYSTEM=="usb", ATTRS{idVendor}=="6603", TAG+="uaccess", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="6603", TAG+="uaccess", MODE="0660"
